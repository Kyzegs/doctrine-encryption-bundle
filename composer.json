{
    "name" : "kyzegs/doctrine-encryption-bundle",
    "type" : "symfony-bundle",
    "description" : "Doctrine field encryption and blind indexes for Symfony applications.",
    "homepage": "https://github.com/kyzegs/doctrine-encryption-bundle",
    "authors" : [{
        "name" : "Kyzegs"
    }],
    "keywords" : [
        "symfony", "doctrine", "encryption", "blind index"
    ],
    "license" : "MIT",
    "require" : {
        "php": ">=8.2",
        "symfony/framework-bundle": "^6.4||^7.4||^8.0",
        "symfony/console": "^6.4||^7.4||^8.0",
        "doctrine/orm": "^2.20||^3.2",
        "doctrine/doctrine-bundle": "^2.12||^3.0",
        "ext-mbstring": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5||^12.0",
        "rector/rector": "^2.1",
        "symfony/phpunit-bridge": "^6.4||^7.4||^8.0",
        "symfony/twig-bundle": "^6.4||^7.4||^8.0"
    },
    "suggest": {
        "symfony/twig-bundle": "Required only when the optional decrypt Twig filter is enabled."
    },
    "autoload": {
        "psr-4": {
            "Kyzegs\\DoctrineEncryptionBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kyzegs\\DoctrineEncryptionBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "rector:check": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true
    }
}
